{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Main",
      "request": "launch",
      "mainClass": "simulator.launcher.Main",
      "projectName": "ecosystem-simulator"
    },
    {
      "type": "java",
      "name": "Main (batch)",
      "request": "launch",
